generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users            User[]
  products         Product[]
  dataEntries      DataEntry[]
  contentMetrics   ContentMetric[]
  financialReports FinancialReport[]
  customMetrics    CustomMetric[]
  overviewCells    OverviewCell[]
  dashboardViews   DashboardView[]
}

enum UserRole {
  COMPANY_ADMIN
  SALES_MANAGER
  ACCOUNT_EXECUTIVE
  SDR
}

model User {
  id             String   @id @default(cuid())
  name           String?
  email          String   @unique
  hashedPassword String
  role           UserRole @default(ACCOUNT_EXECUTIVE)
  organizationId String
  createdAt      DateTime @default(now())

  organization         Organization   @relation(fields: [organizationId], references: [id])
  dataEntries          DataEntry[]
  updatedCustomMetrics CustomMetric[]
}

model Product {
  id             String   @id @default(cuid())
  name           String
  price          Float
  description    String?
  organizationId String
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  dataEntries  DataEntry[]
}

model DataEntry {
  id             String   @id @default(cuid())
  userId         String
  productId      String?
  date           DateTime @default(now())
  organizationId String

  scheduledCalls   Int   @default(0)
  openMessages     Int   @default(0)
  showCalls        Int   @default(0)
  offersMade       Int   @default(0)
  dealsWon         Int   @default(0)
  revenueGenerated Float @default(0)
  cashCollected    Float @default(0)
  refunds          Float @default(0)
  adSpend          Float @default(0)

  // New fields (v2 role-based data entry)
  highTicketLandingPageViews Int   @default(0)
  lowTicketLandingPageViews  Int   @default(0)
  inboundMessages            Int   @default(0)
  outboundMessages           Int   @default(0)
  dials                      Int   @default(0)
  followUps                  Int   @default(0)
  setsBooked                 Int   @default(0)
  callsToday                 Int   @default(0)
  lowTicketCustomers         Int   @default(0)
  monthlyRecurringRevenue    Float @default(0)
  customersCanceled          Int   @default(0)
  businessExpenses           Float @default(0)

  user         User         @relation(fields: [userId], references: [id])
  product      Product?     @relation(fields: [productId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
}

model ContentMetric {
  id             String   @id @default(cuid())
  date           DateTime @default(now())
  organizationId String

  youtubeGrowth           Int @default(0)
  instagramGrowth         Int @default(0)
  qualifiedFollowerGrowth Int @default(0)
  emailOptIns             Int @default(0)
  organicReach            Int @default(0)

  organization Organization @relation(fields: [organizationId], references: [id])
}

model FinancialReport {
  id             String   @id @default(cuid())
  date           DateTime @default(now())
  organizationId String

  businessIncome   Float @default(0)
  businessExpenses Float @default(0)
  preTaxProfit     Float @default(0)
  netAfterTaxes    Float @default(0)

  organization Organization @relation(fields: [organizationId], references: [id])
}

model CustomMetric {
  id             String   @id @default(cuid())
  name           String
  organizationId String
  createdAt      DateTime @default(now())

  type         String   @default("NUMBER") // NUMBER | CURRENCY | CALCULATED
  category     String   @default("sales")  // sales | ads_funnel | organic | business
  role         String?  // e.g. Account Executive
  productIds   Json?    // array of product ids
  firstField   String?  // for CALCULATED: DataEntry field name
  operator     String?  // add | subtract | multiply | divide
  secondField  String?  // for CALCULATED
  showResultAs String?  // currency | number | percent
  status            String   @default("ACTIVE") // ACTIVE | INACTIVE
  pinnedToOverview  Boolean  @default(false)
  updatedAt         DateTime?
  updatedById       String?

  organization Organization      @relation(fields: [organizationId], references: [id])
  updatedBy    User?             @relation(fields: [updatedById], references: [id])
  entries      CustomMetricEntry[]
}

model OverviewCell {
  id             String   @id @default(cuid())
  organizationId String
  viewId         String?
  label          String
  source         String   // "standard" | "custom"
  fieldName      String   // DataEntry field name OR CustomMetric.id
  displayAs      String   @default("number") // "currency" | "number" | "percent"
  position       Int      @default(0)
  createdAt      DateTime @default(now())

  organization   Organization  @relation(fields: [organizationId], references: [id])
  dashboardView  DashboardView? @relation(fields: [viewId], references: [id])
}

model DashboardView {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id])
  cells        OverviewCell[]
}

model CustomMetricEntry {
  id             String   @id @default(cuid())
  customMetricId String
  date           DateTime @default(now())
  value          Float
  userId         String?
  productId      String?

  customMetric CustomMetric @relation(fields: [customMetricId], references: [id])
}
